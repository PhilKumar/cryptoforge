[Unit]
Description=CryptoForge FastAPI Backend — Crypto Perpetual Futures Platform
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/cryptoforge
Environment="PATH=/home/ubuntu/cryptoforge/venv/bin"
EnvironmentFile=/home/ubuntu/cryptoforge/.env
ExecStart=/home/ubuntu/cryptoforge/venv/bin/uvicorn app:app --host 0.0.0.0 --port 9000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
