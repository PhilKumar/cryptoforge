    async def start(self, callback=None):
        while self.running:
            df = await self._fetch_candles()
            row, prev = df.iloc[-1], df.iloc[-2]
            if not self.in_trade and self._should_enter(row, prev):
                await self._place_entry(row)
            elif self.in_trade:
                await self._check_exits(row)
            await asyncio.sleep(self.poll_interval)

    async def _place_entry(self, row): raise NotImplementedError
    async def _check_exits(self, row): raise NotImplementedError

class LiveEngine(BaseEngine):
